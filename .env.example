# AI Configuration (Elige UNA opción gratuita)
AI_PROVIDER=groq

# Opción 1: Groq (RECOMENDADO - Más rápido y fácil)
# Obtén tu API key gratis en: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Opción 2: Cohere (Alternativa gratuita)
# Obtén tu API key gratis en: https://dashboard.cohere.com
# COHERE_API_KEY=your-cohere-api-key-here

# Opción 3: HuggingFace (Alternativa gratuita)
# Obtén tu API key gratis en: https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=hf_your-huggingface-token-here

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Server Configuration
PORT=5000
FLASK_ENV=development

# Optional: For production deployment
# DATABASE_URL=sqlite:///conversations.db
